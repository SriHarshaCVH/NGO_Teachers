# Copy to .env for local development.
# Neon: Dashboard → Connection details → use the pooled connection string for DATABASE_URL
# and the "direct" (non-pooled) connection for DIRECT_URL.

# Pooled (e.g. ends with ?sslmode=require or contains -pooler in host) — serverless-friendly
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Direct — used by Prisma Migrate and introspection (bypasses pooler)
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Auth.js (NextAuth v5) — generate a secret: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"
# Must match the app URL (affects callbacks). Local: http://localhost:3000 — Vercel: https://your-app.vercel.app
AUTH_URL="http://localhost:3000"
