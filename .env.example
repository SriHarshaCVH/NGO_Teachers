# Copy to `.env` for local development. Do not commit real secrets.

# -----------------------------------------------------------------------------
# PostgreSQL (Neon)
# -----------------------------------------------------------------------------
# From Neon: use the pooled connection for DATABASE_URL and the direct
# (non-pooler) host for DIRECT_URL. Both must point at the same database.
#
# Pooled — serverless-friendly (e.g. host contains `-pooler` or `pooler`)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Direct — used by Prisma Migrate (bypasses the pooler; required in schema)
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Local dev: you can use the same two URLs for a local Postgres if you split
# pool vs direct; for Neon, always use Neon’s pooled + direct strings.

# -----------------------------------------------------------------------------
# Auth.js (NextAuth v5)
# -----------------------------------------------------------------------------
# Generate: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"

# Base URL of the app (affects server-side URLs and callbacks).
# Local: http://localhost:3000
# Vercel Production: https://your-domain.com (match the deployed hostname)
# Preview deployments: set per preview or rely on trustHost in auth.config.ts
AUTH_URL="http://localhost:3000"
