{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/auth/[...nextauth]",
      "regex": "^/api/auth/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPnextauth": "nxtPnextauth"
      },
      "namedRegex": "^/api/auth/(?<nxtPnextauth>.+?)(?:/)?$"
    },
    {
      "page": "/api/listings/[id]",
      "regex": "^/api/listings/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/listings/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/ngo/listings/[id]",
      "regex": "^/api/ngo/listings/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/ngo/listings/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/ngo/listings/[id]/edit",
      "regex": "^/ngo/listings/([^/]+?)/edit(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/ngo/listings/(?<nxtPid>[^/]+?)/edit(?:/)?$"
    },
    {
      "page": "/opportunities/[id]",
      "regex": "^/opportunities/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/opportunities/(?<nxtPid>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/login",
      "regex": "^/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/login(?:/)?$"
    },
    {
      "page": "/ngo",
      "regex": "^/ngo(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/ngo(?:/)?$"
    },
    {
      "page": "/ngo/listings",
      "regex": "^/ngo/listings(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/ngo/listings(?:/)?$"
    },
    {
      "page": "/ngo/listings/new",
      "regex": "^/ngo/listings/new(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/ngo/listings/new(?:/)?$"
    },
    {
      "page": "/ngo/profile",
      "regex": "^/ngo/profile(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/ngo/profile(?:/)?$"
    },
    {
      "page": "/opportunities",
      "regex": "^/opportunities(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/opportunities(?:/)?$"
    },
    {
      "page": "/signup",
      "regex": "^/signup(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/signup(?:/)?$"
    },
    {
      "page": "/volunteer",
      "regex": "^/volunteer(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/volunteer(?:/)?$"
    },
    {
      "page": "/volunteer/profile",
      "regex": "^/volunteer/profile(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/volunteer/profile(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}